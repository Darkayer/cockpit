# ============================================================
# COCKPIT — Omgevingsvariabelen
# Kopieer dit bestand naar .env.local en vul de waarden in.
# Deel NOOIT .env.local met anderen of commit het naar git.
# ============================================================

# Next.js / NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=vervang-dit-met-een-sterk-willekeurig-wachtwoord

# ─── Atlassian / Jira Cloud ───────────────────────────────
# Maak een OAuth 2.0 app aan op: https://developer.atlassian.com/console/myapps/
# Scopes nodig: read:jira-work, write:jira-work, read:jira-user, offline_access
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Jouw Jira-domein, bijv: mijnbedrijf.atlassian.net
JIRA_DOMAIN=

# ─── Microsoft 365 / Graph API ────────────────────────────
# Registreer een app op: https://portal.azure.com > App registrations
# Scopes nodig: Mail.Read, Calendars.ReadWrite, User.Read, offline_access
# Redirect URI instellen: http://localhost:3000/api/auth/callback/microsoft-entra-id
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ─── Google (later toe te voegen) ────────────────────────
# Registreer een app op: https://console.cloud.google.com
# Scopes nodig: gmail.readonly, calendar.events, userinfo.email
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database (optioneel voor token-opslag) ───────────────
# Gebruik bijv. Vercel KV, PlanetScale, of Supabase
# DATABASE_URL=
